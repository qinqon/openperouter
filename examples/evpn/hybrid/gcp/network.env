# Network configuration for hybrid on-prem/GCP EVPN setup
# This file is sourced by setup.sh to configure VPN traffic selectors and firewall rules
#
# These values can be auto-discovered from Kubernetes Underlay CRDs:
#   GCP_VTEP_CIDR        -> kubectl --context gcp get underlay -n openperouter-system -o jsonpath='{.items[0].spec.evpn.vtepcidr}'
#   ONPREM_VTEP_CIDR     -> kubectl --context prem get underlay -n openperouter-system -o jsonpath='{.items[0].spec.evpn.vtepcidr}'
#   LEAFGCP_ADDRESS      -> kubectl --context gcp get underlay -n openperouter-system -o jsonpath='{.items[0].spec.neighbors[?(@.ebgpMultiHop==true)].address}'
#   LEAFGCP_ASN          -> kubectl --context gcp get underlay -n openperouter-system -o jsonpath='{.items[0].spec.neighbors[?(@.ebgpMultiHop==true)].asn}'

#######################
# 1. VTEPs CIDRs
#######################

# GCP worker VTEPs (from GCP Underlay CRD spec.evpn.vtepcidr)
GCP_VTEP_CIDR="192.168.11.0/24"

# On-prem Kind cluster VTEPs (from on-prem Underlay CRD spec.evpn.vtepcidr)
ONPREM_VTEP_CIDR="100.65.0.0/24"

# L3VNI test VTEPs (containerlab leafl3test - not discoverable from Kubernetes)
L3VNI_VTEP_CIDR="100.64.0.0/24"

#######################
# 2. Underlay BGP neighbor
#######################

# Leafgcp underlay address (from GCP Underlay CRD neighbors with ebgpMultiHop=true)
LEAFGCP_ADDRESS="10.250.1.3"

# Leafgcp underlay network (derived from LEAFGCP_ADDRESS)
LEAFGCP_UNDERLAY_CIDR="10.250.1.0/24"

#######################
# 3. Link-local (Cloud Router BGP)
#######################

# Link-local addresses for BGP session over VPN tunnel
CLOUD_ROUTER_BGP_IP="169.254.0.1"
LEAFGCP_BGP_IP="169.254.0.2"

#######################
# 4. ASNs
#######################

# Cloud Router ASN (GCP side)
CLOUD_ROUTER_ASN="65001"

# Leafgcp ASN (on-prem side, from GCP Underlay CRD neighbors)
LEAFGCP_ASN="64515"

#######################
# 5. VPN traffic selectors (derived from above)
#######################

# Local traffic selectors (on-prem side - what goes INTO the VPN from on-prem)
# Format: comma-separated list for strongSwan
VPN_LOCAL_TS="${LEAFGCP_UNDERLAY_CIDR},${ONPREM_VTEP_CIDR},${L3VNI_VTEP_CIDR},${LEAFGCP_BGP_IP}/32"

# Remote traffic selectors (GCP side - what comes OUT of the VPN to GCP)
VPN_REMOTE_TS="${GCP_VTEP_CIDR},${CLOUD_ROUTER_BGP_IP}/32"

#######################
# 6. Firewall source ranges
#######################

# Source ranges for GCP firewall rules (allow BGP, VXLAN, ICMP from these networks)
FIREWALL_SOURCE_RANGES="${LEAFGCP_UNDERLAY_CIDR},${ONPREM_VTEP_CIDR},${L3VNI_VTEP_CIDR}"
